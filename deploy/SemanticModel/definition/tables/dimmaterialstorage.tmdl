		summarizeBy: sum
		sourceColumn: CapacityTonnes
		lineageTag: 20000007-0001-0001-0001-200000000003

		annotation SummarizationSetBy = Automatic

	column CurrentLevelTonnes
		dataType: double
		summarizeBy: sum
		sourceColumn: CurrentLevelTonnes
		lineageTag: 20000007-0001-0001-0001-200000000004

		annotation SummarizationSetBy = Automatic

	column MaterialId
		dataType: string
		summarizeBy: none
		sourceColumn: MaterialId
