table dimmaterialstorage
	lineageTag: 20000007-0001-0001-0001-000000000001

	measure 'Storage Count' = COUNTROWS(dimmaterialstorage)
		displayFolder: Measures
		lineageTag: 20000007-0001-0001-0001-100000000001

	measure 'Total Capacity Tonnes' = SUM(dimmaterialstorage[CapacityTonnes])
		displayFolder: Measures
		lineageTag: 20000007-0001-0001-0001-100000000002

	measure 'Storage Utilisation %' = DIVIDE(SUM(dimmaterialstorage[CurrentLevelTonnes]), SUM(dimmaterialstorage[CapacityTonnes]), 0)
		formatString: 0.0%
		displayFolder: Measures
		lineageTag: 20000007-0001-0001-0001-100000000003

	column StorageId
		dataType: string
		summarizeBy: none
		sourceColumn: StorageId
		lineageTag: 20000007-0001-0001-0001-200000000001

		annotation SummarizationSetBy = Automatic

